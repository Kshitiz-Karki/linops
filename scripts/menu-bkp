show_utilities_menu() {
  case $(menu "Utilities" "  xxxxxxxx") in
  *) show_main_menu ;;
  esac

}

show_main_menu() {
  go_to_menu "$(menu "Choose" "󰃀  Quick links\n  Keybindings\n󰂯  Bluetooth\n  Audio\n  Wifi\n󰍜  Toggle Waybar\n  Utilities\n  Power menu\n br search with brave")"
}

go_to_menu() {
  case "${1,,}" in
  *quick*) ~/Documents/linops/scripts/quicklinks.sh ;;
  *keybindings*) ~/Documents/linops/scripts/keybindings.sh ;;
  *bluetooth*) pidof $BLUETUI || $TERMINAL --app-id=bluetui -e ~/bin/$BLUETUI ;;
  *audio*) pidof wiremix || $TERMINAL --app-id=wiremix -e /usr/bin/wiremix ;;
  *wifi*) pidof $NMTUI || $TERMINAL --app-id=nmtui-go -e ~/bin/$NMTUI ;;
  *toggle*) ~/Documents/linops/scripts/toggle-waybar ;;
  *utilities*) show_utilities_menu ;;
  *power*) rofi -show power-menu -modi power-menu:~/Documents/linops/utils/rofi-power-menu ;;
  esac
}

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
